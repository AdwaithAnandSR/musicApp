{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "paths": {
            "@/*": ["./src/*"],
            "@components/*": ["./src/components/*"],
            "@controllers/*": ["./src/controllers/*"],
            "@constants/*": ["./src/constants/*"],
            "@store/*": ["./src/store/*"],
            "@storage/*": ["./src/storage/*"],
            "@utils/*": ["./src/utils/*"],
            "@app/*": ["./src/app/*"],
            "@assets/*": ["./src/assets/*"],
            "@hooks/*": ["./src/hooks/*"],
            "@services/*": ["./src/services/*"],
            "@context/*": ["./src/context/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
